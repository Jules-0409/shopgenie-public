DEEPSEEK_API_KEY=replace-me
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DASHSCOPE_API_KEY=

# Read-only performance connectors. Never use write-capable platform tokens.
# Remote GET response: {"records":[{"record_id":"stable-id","asset_id":"content_xxx","impressions":100,"clicks":10,"orders":1}]}
PLATFORM_API_CONNECTORS_JSON={"dy":{"base_url":"https://metrics.example.com","token":"replace-with-readonly-token","metrics_path":"/v1/metrics"}}

# Optional production auth. When set, every API request except /health must send
# Authorization: Bearer <token>. Values are stable user ids used for data isolation.
# Leave empty for local single-user/dev mode; X-User-Id remains accepted only then.
SHOPGENIE_AUTH_TOKENS_JSON={"replace-with-random-token":"merchant_1"}
